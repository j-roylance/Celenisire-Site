<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">
    <title>Donate - Ella Rises</title>
    <link rel="icon" type="image/png" href="/Ella Rises Logo (3).png">
    <link rel="stylesheet" href="styles.css">
    <style>
        /* Smooth scrolling */
        html {
            scroll-behavior: smooth;
            overflow-y: auto;
        }

        body {
            overflow-y: auto !important;
            overflow-x: hidden;
        }

        /* Landing page specific styles */
        .landing-section {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1), transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .landing-section.visible {
            opacity: 1;
            transform: translateY(0);
        }

        .landing-section.fade-out {
            opacity: 0;
            transform: translateY(-30px);
        }

        /* Smooth card animations */
        .card {
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .card:hover {
            transform: translateY(-10px) scale(1.02);
            box-shadow: 0 20px 50px rgba(255, 182, 193, 0.25);
        }

        /* Form styling enhancements */
        .form-container {
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(10px);
            border: 2px solid rgba(255, 182, 193, 0.2);
            box-shadow: 0 8px 32px rgba(58, 63, 59, 0.08);
        }

        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            border-color: var(--pastel-pink-dark);
            box-shadow: 0 0 0 3px rgba(216, 112, 147, 0.15);
            outline: none;
        }
        
        .form-group label {
            color: var(--dark-charcoal);
            font-weight: 500;
        }
        
        .form-group input,
        .form-group select,
        .form-group textarea {
            border: 1.5px solid var(--border-color);
            transition: all 0.3s ease;
        }
        
        .form-group input:hover,
        .form-group select:hover,
        .form-group textarea:hover {
            border-color: var(--pastel-pink-primary);
        }
    </style>
</head>
<body>
    <!--Navigation-->
    <%- include('./partials/navbar') %>
    
