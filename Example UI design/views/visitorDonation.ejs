    <!-- Email Modal -->
    <div id="emailModal" class="modal" style="display: none;">
        <div class="modal-content" style="max-width: 500px;">
            <span class="close" onclick="closeEmailModal()">&times;</span>
            <h2>Enter Your Email</h2>
            <p style="margin-bottom: 1.5rem;">Please enter your email address to continue with your donation.</p>
            <form id="emailForm" onsubmit="checkEmail(event)">
                <div class="form-group">
                    <label for="emailInput">Email Address *</label>
                    <input type="email" id="emailInput" name="email" required autofocus>
                    <div id="emailStatus" style="margin-top: 0.5rem; font-size: 0.9rem;"></div>
                </div>
                <div class="form-actions" style="justify-content: center; margin-top: 1.5rem;">
                    <button type="button" class="btn btn-secondary" onclick="closeEmailModal()">Cancel</button>
                    <button type="submit" class="btn btn-primary">Continue</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Success/Error Message Modal -->
    <div id="messageModal" class="modal" style="display: none;">
        <div class="modal-content" style="max-width: 500px; text-align: center;">
            <span class="close" onclick="closeMessageModal()">&times;</span>
            <div id="messageContent"></div>
            <div class="form-actions" style="justify-content: center; margin-top: 1.5rem;">
                <button type="button" class="btn btn-primary" onclick="closeMessageModal()">OK</button>
            </div>
