    <style>
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            overflow: auto;
            background-color: rgba(0,0,0,0.4);
        }
        .modal-content {
            background-color: var(--white);
            margin: 15% auto;
            padding: 2rem;
            border: 2px solid var(--pastel-pink-primary);
            border-radius: 20px;
            box-shadow: 0 8px 32px rgba(58, 63, 59, 0.15);
        }
        
        .modal-content h2 {
            color: var(--dark-charcoal);
            margin-bottom: 1rem;
        }
        
        .modal-content p {
            color: var(--text-light);
        }
        .close {
            color: #aaa;
            float: right;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
        }
        .close:hover,
        .close:focus {
            color: #000;
        }
        input[readonly] {
            background-color: #f5f5f5;
            cursor: not-allowed;
        }

        /* Mobile Responsive Styles */
        @media (max-width: 768px) {
            .form-container {
                padding: 2rem 1.5rem !important;
                margin: 1rem !important;
            }

            .section {
                padding: 3rem 1rem !important;
            }

            h1 {
                font-size: clamp(1.5rem, 5vw, 2rem) !important;
            }

            h2 {
                font-size: clamp(1.25rem, 4vw, 1.75rem) !important;
            }

            /* Donation amount buttons - stack on mobile */
            .form-group > div[style*="grid-template-columns"] {
                grid-template-columns: repeat(2, 1fr) !important;
                gap: 0.75rem !important;
            }

            /* Form fields - stack on mobile */
            div[style*="grid-template-columns: 1fr 1fr"] {
                grid-template-columns: 1fr !important;
            }

            div[style*="grid-template-columns: 2fr 1fr 1fr"] {
                grid-template-columns: 1fr !important;
            }

            .btn {
                width: 100%;
                padding: 0.875rem 1.5rem;
            }

            .modal-content {
                margin: 10% auto;
                padding: 1.5rem;
                max-width: 95%;
            }
        }

        @media (max-width: 480px) {
            .form-container {
                padding: 1.5rem 1rem !important;
            }

            .section {
                padding: 2rem 0.5rem !important;
            }

            /* Donation amount buttons - single column on very small screens */
            .form-group > div[style*="grid-template-columns"] {
                grid-template-columns: 1fr !important;
            }

            .btn {
                padding: 0.75rem 1.25rem;
                font-size: 0.9rem;
            }
        }
    </style>

    <script>
        let participantFound = false;
        let participantId = null;

        // Open email modal
        function openEmailModal() {
            document.getElementById('emailModal').style.display = 'block';
            document.getElementById('emailInput').focus();
        }

        // Close email modal
        function closeEmailModal() {
            document.getElementById('emailModal').style.display = 'none';
            document.getElementById('emailForm').reset();
            document.getElementById('emailStatus').textContent = '';
        }

        // Close message modal
        function closeMessageModal() {
            document.getElementById('messageModal').style.display = 'none';
            if (document.getElementById('messageContent').classList.contains('success')) {
                // Reset form and hide it
                document.getElementById('donationForm').reset();
                document.getElementById('donationForm').style.display = 'none';
                document.getElementById('donateButtonContainer').style.display = 'block';
                participantFound = false;
                participantId = null;
            }
        }

        // Check email and populate form
        function checkEmail(event) {
            event.preventDefault();
            const email = document.getElementById('emailInput').value.trim();
            const emailStatus = document.getElementById('emailStatus');
            
            if (!email) {
                emailStatus.innerHTML = '<span style="color: red;">Please enter an email address</span>';
                return;
            }

            emailStatus.innerHTML = '<span style="color: #666;">Checking email...</span>';

            fetch('/checkParticipantEmail', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ email: email })
            })
            .then(response => response.json())
            .then(data => {
                if (data.found) {
                    participantFound = true;
                    participantId = data.participant.participantid;
                    emailStatus.innerHTML = '<span style="color: green;">✓ Email found</span>';
                    
                    // Close email modal
                    closeEmailModal();
                    
                    // Populate form with participant data and make fields readonly
                    document.getElementById('email').value = data.participant.participantemail;
                    document.getElementById('firstName').value = data.participant.participantfirstname || '';
                    document.getElementById('lastName').value = data.participant.participantlastname || '';
                    document.getElementById('phone').value = data.participant.participantphone || '';
                    document.getElementById('city').value = data.participant.participantcity || '';
                    document.getElementById('state').value = data.participant.participantstate || '';
                    document.getElementById('zip').value = data.participant.participantzip || '';
                    
                    // Make all participant fields readonly
                    document.getElementById('email').setAttribute('readonly', 'readonly');
                    document.getElementById('firstName').setAttribute('readonly', 'readonly');
                    document.getElementById('lastName').setAttribute('readonly', 'readonly');
                    document.getElementById('phone').setAttribute('readonly', 'readonly');
                    document.getElementById('city').setAttribute('readonly', 'readonly');
                    document.getElementById('state').setAttribute('readonly', 'readonly');
                    document.getElementById('zip').setAttribute('readonly', 'readonly');
                    
                    // Remove required indicators
                    document.getElementById('phoneRequired').style.display = 'none';
                    document.getElementById('cityRequired').style.display = 'none';
                    document.getElementById('stateRequired').style.display = 'none';
                    document.getElementById('zipRequired').style.display = 'none';
                    document.getElementById('phone').removeAttribute('required');
                    document.getElementById('city').removeAttribute('required');
                    document.getElementById('state').removeAttribute('required');
                    document.getElementById('zip').removeAttribute('required');
                    
                    // Show form
                    document.getElementById('donateButtonContainer').style.display = 'none';
                    document.getElementById('donationForm').style.display = 'block';
                    
                    // Scroll to form smoothly
                    setTimeout(() => {
                        document.getElementById('donationForm').scrollIntoView({ behavior: 'smooth', block: 'start' });
                    }, 100);
                } else {
                    participantFound = false;
                    participantId = null;
                    emailStatus.innerHTML = '<span style="color: orange;">Email not found. You can fill out your information below.</span>';
                    
                    // Close email modal
                    closeEmailModal();
                    
                    // Clear form and make fields editable
                    document.getElementById('email').value = email;
                    document.getElementById('firstName').value = '';
                    document.getElementById('lastName').value = '';
                    document.getElementById('phone').value = '';
                    document.getElementById('city').value = '';
                    document.getElementById('state').value = '';
                    document.getElementById('zip').value = '';
                    
                    // Remove readonly from fields
                    document.getElementById('email').removeAttribute('readonly');
                    document.getElementById('firstName').removeAttribute('readonly');
                    document.getElementById('lastName').removeAttribute('readonly');
                    document.getElementById('phone').removeAttribute('readonly');
                    document.getElementById('city').removeAttribute('readonly');
                    document.getElementById('state').removeAttribute('readonly');
                    document.getElementById('zip').removeAttribute('readonly');
                    
                    // Add required indicators for new participants
                    document.getElementById('phoneRequired').style.display = 'inline';
                    document.getElementById('cityRequired').style.display = 'inline';
                    document.getElementById('stateRequired').style.display = 'inline';
                    document.getElementById('zipRequired').style.display = 'inline';
                    document.getElementById('phone').setAttribute('required', 'required');
                    document.getElementById('city').setAttribute('required', 'required');
                    document.getElementById('state').setAttribute('required', 'required');
                    document.getElementById('zip').setAttribute('required', 'required');
                    
                    // Show form
                    document.getElementById('donateButtonContainer').style.display = 'none';
                    document.getElementById('donationForm').style.display = 'block';
                    
                    // Scroll to form smoothly
                    setTimeout(() => {
                        document.getElementById('donationForm').scrollIntoView({ behavior: 'smooth', block: 'start' });
                    }, 100);
                }
            })
            .catch(error => {
                console.error('Error checking email:', error);
                emailStatus.innerHTML = '<span style="color: red;">Error checking email. Please try again.</span>';
            });
        }

        // Amount button selection
        const amountButtons = document.querySelectorAll('.btn-amount');
        const customAmountInput = document.getElementById('customAmount');
        
        amountButtons.forEach(button => {
            button.addEventListener('click', function() {
                amountButtons.forEach(btn => btn.classList.remove('btn-primary'));
                amountButtons.forEach(btn => btn.classList.add('btn-secondary'));
                this.classList.remove('btn-secondary');
                this.classList.add('btn-primary');
                customAmountInput.value = this.dataset.amount;
            });
        });

        // Form submission
        document.getElementById('donationForm').addEventListener('submit', function(e) {
            e.preventDefault();
            
            // Get form elements with null checks
            const emailEl = document.getElementById('email');
            const firstNameEl = document.getElementById('firstName');
            const lastNameEl = document.getElementById('lastName');
            const phoneEl = document.getElementById('phone');
            const cityEl = document.getElementById('city');
            const stateEl = document.getElementById('state');
            const zipEl = document.getElementById('zip');
            const customAmountEl = document.getElementById('customAmount');
            
            // Check if form is visible and elements exist
            if (!emailEl || !firstNameEl || !lastNameEl || !customAmountEl) {
                console.error('Required form elements not found');
                showMessage('Form error: Please refresh the page and try again.', false);
                return;
            }
            
            const formData = {
                email: emailEl.value,
                firstName: firstNameEl.value,
                lastName: lastNameEl.value,
                phone: phoneEl ? phoneEl.value : '',
                city: cityEl ? cityEl.value : '',
                state: stateEl ? stateEl.value : '',
                zip: zipEl ? zipEl.value : '',
                customAmount: customAmountEl.value
            };
            
            // Validate required fields
            if (!formData.email || !formData.firstName || !formData.lastName || !formData.customAmount) {
                showMessage('Please fill out all required fields (Email, First Name, Last Name, and Donation Amount).', false);
                return;
            }
            
            // If participant not found, validate required participant fields
            if (!participantFound) {
                if (!formData.phone || !formData.city || !formData.state || !formData.zip) {
                    showMessage('Please fill out all required participant information (Phone, City, State, ZIP Code).', false);
                    return;
                }
            }
            
            // Submit donation
            fetch('/submitVisitorDonation', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(formData)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showMessage(data.message, true);
                    this.reset();
                } else {
                    showMessage(data.message, false);
                }
            })
            .catch(error => {
                console.error('Error submitting donation:', error);
                showMessage('An error occurred while processing your donation. Please try again.', false);
            });
        });

        // Show message modal
        function showMessage(message, isSuccess) {
            const messageContent = document.getElementById('messageContent');
            messageContent.innerHTML = isSuccess 
                ? `<div style="color: #155724;"><h2 style="color: #155724;">✓ Success!</h2><p>${message}</p></div>`
                : `<div style="color: #721c24;"><h2 style="color: #721c24;">⚠ Error</h2><p>${message}</p></div>`;
            messageContent.className = isSuccess ? 'success' : 'error';
            document.getElementById('messageModal').style.display = 'block';
        }

        // Close modal when clicking outside
        window.onclick = function(event) {
            const emailModal = document.getElementById('emailModal');
            const messageModal = document.getElementById('messageModal');
            if (event.target === emailModal) {
                closeEmailModal();
            }
            if (event.target === messageModal) {
                closeMessageModal();
            }
        }

        // Close modal on ESC key
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
                closeEmailModal();
                closeMessageModal();
            }
        });

        // Smooth scroll reveal animations with fade in/out
        const observerOptions = {
            threshold: [0, 0.1, 0.3, 0.5, 0.7, 1],
            rootMargin: '0px'
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                const rect = entry.boundingClientRect;
                const viewportHeight = window.innerHeight;
                const isInView = entry.isIntersecting && rect.top < viewportHeight && rect.bottom > 0;
                
                if (isInView) {
                    entry.target.classList.add('visible');
                    entry.target.classList.remove('fade-out');
                } else {
                    // Fade out when scrolling away
                    if (rect.bottom < 0 || rect.top > viewportHeight) {
                        entry.target.classList.remove('visible');
                        entry.target.classList.add('fade-out');
                    }
                }
            });
        }, observerOptions);

        // Observe all landing sections
        document.querySelectorAll('.landing-section').forEach(section => {
            observer.observe(section);
            // Make hero section visible immediately on load if it's in view
            if (section.classList.contains('hero')) {
                const rect = section.getBoundingClientRect();
                if (rect.top < window.innerHeight && rect.bottom > 0) {
                    section.classList.add('visible');
                }
            }
        });
    </script>
</body>
</html>

