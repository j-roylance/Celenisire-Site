<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">
    <title>Events Maintenance - Ella Rises</title>
    <link rel="icon" type="image/png" href="/Ella Rises Logo (3).png">
    <link rel="stylesheet" href="/styles.css">
    <style>
        /* Smooth scrolling */
        html {
            scroll-behavior: smooth;
            overflow-y: auto;
        }

        body {
            overflow-y: auto !important;
            overflow-x: hidden;
        }

        .section {
            overflow-y: visible !important;
            min-height: auto !important;
        }

        /* Enhanced search and action bar */
        .search-action-bar {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 182, 193, 0.2);
            border-radius: 20px;
            padding: 1.5rem;
            margin-bottom: 2rem;
            box-shadow: 0 8px 32px rgba(58, 63, 59, 0.08);
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .search-action-bar:hover {
            box-shadow: 0 12px 40px rgba(58, 63, 59, 0.12);
        }

        .search-container {
            display: flex;
            gap: 1rem;
            align-items: center;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
        }

        .search-box {
            flex: 1;
            min-width: 250px;
        }

        .search-box input {
            width: 100%;
            padding: 0.875rem 1.25rem;
            border: 1.5px solid rgba(255, 182, 193, 0.3);
            border-radius: 50px;
            font-size: 1rem;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(5px);
        }

        .search-box input:focus {
            outline: none;
            border-color: var(--pastel-pink-dark);
            box-shadow: 0 0 0 3px rgba(216, 112, 147, 0.15);
            background: var(--white);
        }

        .search-box input:hover {
            border-color: var(--pastel-pink-primary);
        }

        .action-buttons {
            display: flex;
            gap: 1rem;
            align-items: center;
        }

        .btn {
            border-radius: 50px;
            padding: 0.875rem 2rem;
            font-weight: 500;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 4px 15px rgba(255, 182, 193, 0.2);
        }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(255, 182, 193, 0.35);
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--pastel-pink-primary) 0%, var(--pastel-pink-dark) 100%);
            border: none;
        }

        .btn-primary:hover {
            background: linear-gradient(135deg, var(--pastel-pink-dark) 0%, var(--pastel-pink-primary) 100%);
        }

        .btn-secondary {
            background: rgba(255, 255, 255, 0.9);
            border: 1.5px solid var(--pastel-pink-primary);
            color: var(--pastel-pink-dark);
        }

        .btn-secondary:hover {
            background: var(--pastel-pink-lighter);
            border-color: var(--pastel-pink-dark);
        }

        .page-header {
            margin-bottom: 2rem;
        }

        .page-header h1 {
            font-family: 'DM Serif Display', serif;
            color: var(--dark-charcoal);
            margin-bottom: 0.5rem;
        }

        .page-header p {
            color: var(--text-light);
            font-size: 1.1rem;
        }

        /* Survey Results Styling - Smaller text */
        .survey-results-section {
            font-size: 0.85rem;
        }

        .survey-results-section h3 {
            font-size: 1.1rem;
        }

        .survey-average-score {
            font-size: 0.9rem;
        }

        .survey-results-table {
            font-size: 0.8rem;
        }

        .survey-results-table th,
        .survey-results-table td {
            padding: 0.5rem 0.4rem;
            font-size: 0.8rem;
        }

        .survey-results-table th {
            font-size: 0.75rem;
            font-weight: 600;
        }

        .survey-comment-btn {
            padding: 0.3rem 0.6rem !important;
            font-size: 0.7rem !important;
            white-space: nowrap;
        }

        /* Responsive design */
        @media (max-width: 768px) {
            .search-action-bar {
                padding: 1rem;
            }

            .search-container {
                flex-direction: column;
                gap: 1rem;
            }

            .search-box {
                min-width: 100%;
            }

            .action-buttons {
                width: 100%;
            }

            .btn {
                width: 100%;
            }

            .search-box input {
                width: 100%;
            }

            .survey-results-table {
                font-size: 0.7rem;
            }

            .survey-results-table th,
            .survey-results-table td {
                padding: 0.4rem 0.3rem;
                font-size: 0.7rem;
            }

            .survey-comment-btn {
                padding: 0.25rem 0.5rem !important;
                font-size: 0.65rem !important;
            }
        }
    </style>
</head>
<body>
    <!--Navigation-->
    <%- include('../partials/navbar')%>

    <!-- Main Content Section -->
    <section class="section" style="background-color: var(--white) !important; background-image: none !important; padding: 4rem 2rem; min-height: auto; overflow-y: visible;">
        <div class="container" style="max-width: 1200px; margin: 0 auto; padding: 0;">
            <!-- Page Header -->
            <div class="page-header" style="text-align: center; margin-bottom: 3rem; background-color: transparent; padding: 0;">
                <h1>Events Maintenance</h1>
                <p>Manage Event records and donor information. Manager access only.</p>
            </div>
            
            <!-- Search and Action Bar -->
            <div class="search-action-bar">
                <div class="search-container">
                    <div class="search-box">
                        <input type="text" id="searchNameInput" name="searchName" placeholder="Search by Event Name..." autocomplete="off">
                    </div>
                    <div class="search-box">
                        <input type="text" id="searchDateInput" name="searchDate" placeholder="Search by Date (e.g., May 15, 2025, 10:00 AM)..." autocomplete="off">
                    </div>
                </div>
                <div class="action-buttons">
                    <button class="btn btn-primary" onclick="openModal('eventModal', 'add')">
                        Add New Event
                    </button>
                </div>
            </div>
         
            <!-- Content Area -->
            <div style="margin-top: 2.5rem;">
                <h2 class="mb-4" style="font-family: 'DM Serif Display', serif; color: var(--dark-charcoal); font-size: 2rem; margin-bottom: 1.5rem;">Event List</h2>
            
            <!-- Display error message if available -->
            <% if (typeof error_message !== 'undefined' && error_message) { %>
                <div class="alert alert-error" role="alert">
                    <%= error_message %>
                </div>
            <% } %>
            
            <!-- Display Events list -->
            <div id="eventCardsContainer" class="participant-cards-grid">
                <!-- Cards will be dynamically rendered here -->
            </div>
            <div id="noEventsMessage" class="alert alert-error" role="alert" style="display: none;">
                No Events found.
            </div>
            </div>
            </div>
        </div>
    </section>

    <!-- Include the add/edit modal -->
    <%- include('../partials/addEditModal', {
        modalId: 'eventModal',
        modalTitle: 'Add Event',
        formId: 'eventModal-form',
        formAction: '/mEvent/save',
        fields: [
            { name: 'eventname', label: 'Event Name', type: 'text', required: true },
            { name: 'eventdatetimestart', label: 'Event Start Date/Time', type: 'datetime-local', required: false },
            { name: 'eventdatetimeend', label: 'Event End Date/Time', type: 'datetime-local', required: false },
            { name: 'eventlocation', label: 'Event Location', type: 'text', required: false },
            { name: 'eventcapacity', label: 'Event Capacity', type: 'number', required: false },
            { name: 'eventregistrationdeadline', label: 'Event Registration Deadline', type: 'datetime-local', required: false }
        ]
    }) %>

    <!-- Include the delete confirmation modal -->
    <%- include('../partials/deleteConfirmModal') %>

    <!-- Event Detail Modal -->
    <div id="eventDetailModal" class="participant-modal">
        <div class="participant-modal-content">
            <div class="participant-modal-header">
                <h2 id="eventModalName">Event Details</h2>
                <span class="participant-modal-close" onclick="closeEventModal()">&times;</span>
            </div>
            <div class="participant-modal-body" id="eventModalBody">
                <div style="text-align: center; padding: 2rem;">
                    <p>Loading event details...</p>
                </div>
            </div>
            <div class="participant-modal-footer" id="eventModalFooter" style="display: none;">
                <button class="btn btn-secondary" id="eventEditBtn">Edit</button>
                <button class="btn btn-danger" id="eventDeleteBtn">Delete</button>
            </div>
        </div>
    </div>

    <!-- Survey Comment Modal -->
    <div id="surveyCommentModal" class="participant-modal">
        <div class="participant-modal-content" style="max-width: 600px;">
            <div class="participant-modal-header">
                <h2 id="surveyCommentModalName">Survey Comment</h2>
                <span class="participant-modal-close" onclick="closeSurveyCommentModal()">&times;</span>
            </div>
            <div class="participant-modal-body" id="surveyCommentModalBody">
                <div style="padding: 1rem;">
                    <p id="surveyCommentText" style="white-space: pre-wrap; word-wrap: break-word; line-height: 1.6;"></p>
                </div>
            </div>
            <div class="participant-modal-footer">
                <button class="btn btn-secondary" onclick="closeSurveyCommentModal()">Close</button>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-content">
            <p>&copy; 2025 Ella Rises. All rights reserved. | Empowering lives, building futures.</p>
        </div>
    </footer>

    <script src="/modalHelper.js"></script>
    <script>
        let currentEventData = null;
        let allEvents = <%- JSON.stringify(allEvents || []) %>;
        let displayedEvents = [];

        // Initialize page - show 20 random events
        document.addEventListener('DOMContentLoaded', function() {
            // Shuffle and get 20 random events
            const shuffled = [...allEvents].sort(() => 0.5 - Math.random());
            displayedEvents = shuffled.slice(0, 20);
            renderEventCards(displayedEvents);

            // Set up real-time search for event name
            const searchNameInput = document.getElementById('searchNameInput');
            if (searchNameInput) {
                searchNameInput.addEventListener('input', function() {
                    performSearch();
                });
            }

            // Set up real-time search for event date
            const searchDateInput = document.getElementById('searchDateInput');
            if (searchDateInput) {
                searchDateInput.addEventListener('input', function() {
                    performSearch();
                });
            }
        });

        // Helper function to format date as "May 15, 2025, 10:00 AM"
        function formatDateTime(dateString) {
            if (!dateString) return '';
            const date = new Date(dateString);
            if (isNaN(date.getTime())) return '';
            
            const months = ['January', 'February', 'March', 'April', 'May', 'June', 
                          'July', 'August', 'September', 'October', 'November', 'December'];
            const month = months[date.getMonth()];
            const day = date.getDate();
            const year = date.getFullYear();
            
            let hours = date.getHours();
            const minutes = date.getMinutes();
            const ampm = hours >= 12 ? 'PM' : 'AM';
            hours = hours % 12;
            hours = hours ? hours : 12; // the hour '0' should be '12'
            const minutesStr = minutes < 10 ? '0' + minutes : minutes;
            
            return `${month} ${day}, ${year}, ${hours}:${minutesStr} ${ampm}`;
        }

        // Helper function to create multiple searchable date formats for flexible matching
        function getSearchableDateFormats(dateString) {
            if (!dateString) return [];
            const date = new Date(dateString);
            if (isNaN(date.getTime())) return [];
            
            const months = ['January', 'February', 'March', 'April', 'May', 'June', 
                          'July', 'August', 'September', 'October', 'November', 'December'];
            const monthAbbr = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 
                              'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
            
            const month = months[date.getMonth()];
            const monthShort = monthAbbr[date.getMonth()];
            const day = date.getDate();
            const year = date.getFullYear();
            
            let hours = date.getHours();
            const minutes = date.getMinutes();
            const ampm = hours >= 12 ? 'PM' : 'AM';
            hours = hours % 12;
            hours = hours ? hours : 12;
            const minutesStr = minutes < 10 ? '0' + minutes : minutes;
            
            // Create multiple formats for flexible searching
            const formats = [
                `${month} ${day}, ${year}, ${hours}:${minutesStr} ${ampm}`,  // Full format
                `${month} ${day}, ${year}`,                                   // Month Day, Year
                `${month} ${day}`,                                            // Month Day
                `${monthShort} ${day}, ${year}`,                              // Abbr Month Day, Year
                `${monthShort} ${day}`,                                        // Abbr Month Day
                `${month} ${day}, ${year}, ${hours}:${minutesStr} ${ampm}`,   // Full with comma
                `${monthShort} ${day}, ${year}, ${hours}:${minutesStr} ${ampm}`, // Abbr with time
                `${month} ${day} ${year}`,                                     // Month Day Year (no comma)
                `${monthShort} ${day} ${year}`,                                // Abbr Month Day Year (no comma)
                `${year}`,                                                     // Just year
                `${month}`,                                                    // Just month
                `${monthShort}`,                                               // Just month abbreviation
                `${day}`,                                                      // Just day
                `${hours}:${minutesStr} ${ampm}`                               // Just time
            ];
            
            return formats;
        }

        // Perform search with both name and date filters
        function performSearch() {
            const nameSearch = document.getElementById('searchNameInput')?.value.trim() || '';
            const dateSearch = document.getElementById('searchDateInput')?.value.trim() || '';
            
            // If both searches are empty, show 20 random events
            if (!nameSearch && !dateSearch) {
                const shuffled = [...allEvents].sort(() => 0.5 - Math.random());
                displayedEvents = shuffled.slice(0, 20);
                renderEventCards(displayedEvents);
                return;
            }
            
            // Filter events based on both search terms
            const nameSearchLower = nameSearch.toLowerCase();
            const dateSearchLower = dateSearch.toLowerCase();
            
            displayedEvents = allEvents.filter(event => {
                let nameMatch = true;
                let dateMatch = true;
                
                // Check name search (searches in name, type, location, description)
                if (nameSearch) {
                    const eventName = (event.eventname || '').toLowerCase();
                    const eventType = (event.eventtype || '').toLowerCase();
                    const eventLocation = (event.eventlocation || '').toLowerCase();
                    const eventDescription = (event.eventdescription || '').toLowerCase();
                    
                    nameMatch = eventName.includes(nameSearchLower) || 
                               eventType.includes(nameSearchLower) ||
                               eventLocation.includes(nameSearchLower) ||
                               eventDescription.includes(nameSearchLower);
                }
                
                // Check date search (searches in start date, end date, registration deadline)
                if (dateSearch) {
                    // Get all searchable date formats for each date
                    const startDateFormats = getSearchableDateFormats(event.eventdatetimestart).map(f => f.toLowerCase());
                    const endDateFormats = getSearchableDateFormats(event.eventdatetimeend).map(f => f.toLowerCase());
                    const regDeadlineFormats = getSearchableDateFormats(event.eventregistrationdeadline).map(f => f.toLowerCase());
                    
                    // Check if search term matches any of the date formats
                    dateMatch = startDateFormats.some(format => format.includes(dateSearchLower)) ||
                               endDateFormats.some(format => format.includes(dateSearchLower)) ||
                               regDeadlineFormats.some(format => format.includes(dateSearchLower));
                }
                
                // Event must match both criteria (if both are provided)
                return nameMatch && dateMatch;
            });
            
            renderEventCards(displayedEvents);
        }

        // Render event cards
        function renderEventCards(events) {
            const container = document.getElementById('eventCardsContainer');
            const noResultsMessage = document.getElementById('noEventsMessage');
            
            if (!container) return;

            if (events.length === 0) {
                container.innerHTML = '';
                if (noResultsMessage) {
                    noResultsMessage.style.display = 'block';
                }
                return;
            }

            if (noResultsMessage) {
                noResultsMessage.style.display = 'none';
            }

            container.innerHTML = events.map(event => {
                const eventName = event.eventname || 'Unnamed Event';
                const startDateTime = event.eventdatetimestart 
                    ? new Date(event.eventdatetimestart).toLocaleString('en-US', { 
                        month: 'short', 
                        day: 'numeric', 
                        year: 'numeric',
                        hour: 'numeric',
                        minute: '2-digit',
                        hour12: true
                    })
                    : 'Date TBD';
                return `
                    <div class="participant-card" data-event-id="${event.eventoccurrenceid}">
                        <p class="participant-card-name">${eventName}</p>
                        <p class="participant-card-subtitle">${startDateTime}</p>
                    </div>
                `;
            }).join('');

            // Add click handlers to all cards
            container.querySelectorAll('.participant-card').forEach(card => {
                card.addEventListener('click', function() {
                    const eventId = this.getAttribute('data-event-id');
                    if (eventId) {
                        loadEventDetails(eventId);
                    }
                });
            });
        }


        // Load event details via AJAX
        function loadEventDetails(eventOccurrenceId) {
            const modal = document.getElementById('eventDetailModal');
            const modalBody = document.getElementById('eventModalBody');
            const modalFooter = document.getElementById('eventModalFooter');
            const modalName = document.getElementById('eventModalName');
            
            // Clear previous data immediately
            modalName.textContent = 'Loading...';
            
            // Show modal with loading state
            modal.classList.add('active');
            modalBody.innerHTML = '<div style="text-align: center; padding: 2rem;"><p>Loading event details...</p></div>';
            modalFooter.style.display = 'none';

            // Fetch event details with cache control
            fetch(`/api/event/${eventOccurrenceId}`, {
                method: 'GET',
                cache: 'no-store',
                headers: {
                    'Cache-Control': 'no-cache',
                    'Pragma': 'no-cache'
                }
            })
                .then(response => {
                    if (!response.ok) {
                        throw new Error('Failed to fetch event details');
                    }
                    return response.json();
                })
                .then(data => {
                    currentEventData = data;
                    populateEventModal(data);
                    modalFooter.style.display = 'flex';
                })
                .catch(error => {
                    console.error('Error loading event details:', error);
                    modalBody.innerHTML = '<div class="participant-empty-state"><p>Error loading event details. Please try again.</p></div>';
                    modalName.textContent = 'Error';
                });
        }

        // Populate modal with event data
        function populateEventModal(data) {
            const modalName = document.getElementById('eventModalName');
            const modalBody = document.getElementById('eventModalBody');
            const event = data.event;

            // Set modal header name
            modalName.textContent = event.eventname || 'Event Details';

            // Build modal content
            let html = '';

            // Event Info Section
            html += '<div class="participant-modal-section">';
            html += '<h3>Event Information</h3>';
            html += '<div class="participant-info-grid">';
            html += `<div class="participant-info-item"><span class="participant-info-label">Event Name</span><span class="participant-info-value">${event.eventname || 'N/A'}</span></div>`;
            html += `<div class="participant-info-item"><span class="participant-info-label">Event Type</span><span class="participant-info-value">${event.eventtype || 'N/A'}</span></div>`;
            html += `<div class="participant-info-item"><span class="participant-info-label">Location</span><span class="participant-info-value">${event.eventlocation || 'N/A'}</span></div>`;
            html += `<div class="participant-info-item"><span class="participant-info-label">Start Date/Time</span><span class="participant-info-value">${event.eventdatetimestart ? new Date(event.eventdatetimestart).toLocaleString() : 'N/A'}</span></div>`;
            html += `<div class="participant-info-item"><span class="participant-info-label">End Date/Time</span><span class="participant-info-value">${event.eventdatetimeend ? new Date(event.eventdatetimeend).toLocaleString() : 'N/A'}</span></div>`;
            html += `<div class="participant-info-item"><span class="participant-info-label">Capacity</span><span class="participant-info-value">${event.eventcapacity || 'N/A'}</span></div>`;
            html += `<div class="participant-info-item"><span class="participant-info-label">Registration Deadline</span><span class="participant-info-value">${event.eventregistrationdeadline ? new Date(event.eventregistrationdeadline).toLocaleString() : 'N/A'}</span></div>`;
            html += `<div class="participant-info-item"><span class="participant-info-label">Recurrence Pattern</span><span class="participant-info-value">${event.eventrecurrencepattern || 'N/A'}</span></div>`;
            if (event.eventdescription) {
                html += `<div class="participant-info-item" style="grid-column: 1 / -1;"><span class="participant-info-label">Description</span><span class="participant-info-value">${event.eventdescription}</span></div>`;
            }
            html += '</div>';
            html += '</div>';

            // Statistics Section
            html += '<div class="participant-modal-section">';
            html += '<h3>Registration Statistics</h3>';
            html += '<div class="participant-info-grid">';
            html += `<div class="participant-info-item"><span class="participant-info-label">Total Registered</span><span class="participant-info-value">${data.statistics.totalRegistered}</span></div>`;
            html += `<div class="participant-info-item"><span class="participant-info-label">Total Attended</span><span class="participant-info-value">${data.statistics.totalAttended}</span></div>`;
            if (event.eventcapacity) {
                const capacity = parseInt(event.eventcapacity) || 0;
                const registered = data.statistics.totalRegistered;
                const percentage = capacity > 0 ? Math.round((registered / capacity) * 100) : 0;
                html += `<div class="participant-info-item"><span class="participant-info-label">Capacity Utilization</span><span class="participant-info-value">${percentage}% (${registered}/${capacity})</span></div>`;
            }
            html += '</div>';
            html += '</div>';

            // Participants Section
            html += '<div class="participant-modal-section">';
            html += '<h3>Participants</h3>';
            if (data.participants && data.participants.length > 0) {
                html += '<table class="participant-donations-table">';
                html += '<thead><tr><th>Name</th><th>Email</th><th>Status</th><th>Attended</th></tr></thead>';
                html += '<tbody>';
                data.participants.forEach(participant => {
                    const fullName = `${participant.participantfirstname || ''} ${participant.participantlastname || ''}`.trim();
                    const status = participant.registrationstatus || 'N/A';
                    const attended = participant.registrationattendedflag ? 'Yes' : 'No';
                    html += `<tr><td>${fullName}</td><td>${participant.participantemail || 'N/A'}</td><td>${status}</td><td>${attended}</td></tr>`;
                });
                html += '</tbody>';
                html += '</table>';
            } else {
                html += '<div class="participant-empty-state">No participants registered.</div>';
            }
            html += '</div>';

            // Survey Results Section
            html += '<div class="participant-modal-section survey-results-section">';
            html += '<h3>Survey Results</h3>';
            if (data.surveys && data.surveys.length > 0) {
                // Calculate averages
                const scores = data.surveys.filter(s => s.surveyoverallscore);
                const avgScore = scores.length > 0 
                    ? (scores.reduce((sum, s) => sum + (parseInt(s.surveyoverallscore) || 0), 0) / scores.length).toFixed(1)
                    : 'N/A';
                
                html += `<div class="survey-average-score" style="margin-bottom: 1rem;"><strong>Average Overall Score: ${avgScore}</strong></div>`;
                html += '<table class="participant-donations-table survey-results-table">';
                html += '<thead><tr><th>Participant</th><th>Overall Score</th><th>Satisfaction</th><th>Usefulness</th><th>Instructor</th><th>Recommendation</th><th>Comment</th></tr></thead>';
                html += '<tbody>';
                data.surveys.forEach((survey, index) => {
                    const participantName = `${survey.participantfirstname || ''} ${survey.participantlastname || ''}`.trim() || 'Anonymous';
                    const hasComment = survey.surveycomments && survey.surveycomments.trim();
                    // Escape single quotes in participant name for onclick handler
                    const escapedName = participantName.replace(/'/g, "\\'");
                    html += `<tr>
                        <td>${participantName}</td>
                        <td>${survey.surveyoverallscore || 'N/A'}</td>
                        <td>${survey.surveysatisfactionscore || 'N/A'}</td>
                        <td>${survey.surveyusefulnessscore || 'N/A'}</td>
                        <td>${survey.surveyinstructorscore || 'N/A'}</td>
                        <td>${survey.surveyrecommendationscore || 'N/A'}</td>
                        <td>
                            <button class="btn btn-small btn-secondary survey-comment-btn" onclick="openSurveyCommentModal('${escapedName}', ${index})" ${!hasComment ? 'disabled style="opacity: 0.5; cursor: not-allowed;"' : ''}>
                                ${hasComment ? 'View Comment' : 'No Comment'}
                            </button>
                        </td>
                    </tr>`;
                });
                html += '</tbody>';
                html += '</table>';
                
                // Store survey data for comment modal access
                window.currentSurveyData = data.surveys;
            } else {
                html += '<div class="participant-empty-state">No survey results available.</div>';
            }
            html += '</div>';

            modalBody.innerHTML = html;

            // Set up edit and delete button handlers
            setupEventModalButtons(event);
        }

        // Setup edit and delete buttons
        function setupEventModalButtons(event) {
            const editBtn = document.getElementById('eventEditBtn');
            const deleteBtn = document.getElementById('eventDeleteBtn');

            // Edit button
            editBtn.onclick = function() {
                closeEventModal();
                const button = document.createElement('button');
                button.setAttribute('data-eventoccurrenceid', event.eventoccurrenceid);
                button.setAttribute('data-eventtypeid', event.eventtypeid || '');
                button.setAttribute('data-eventname', event.eventname || '');
                button.setAttribute('data-eventdatetimestart', event.eventdatetimestart ? new Date(event.eventdatetimestart).toISOString().slice(0, 16) : '');
                button.setAttribute('data-eventdatetimeend', event.eventdatetimeend ? new Date(event.eventdatetimeend).toISOString().slice(0, 16) : '');
                button.setAttribute('data-eventlocation', event.eventlocation || '');
                button.setAttribute('data-eventcapacity', event.eventcapacity || '');
                button.setAttribute('data-eventregistrationdeadline', event.eventregistrationdeadline ? new Date(event.eventregistrationdeadline).toISOString().slice(0, 16) : '');
                openEventModalFromButton(button, 'eventModal');
            };

            // Delete button
            deleteBtn.onclick = function() {
                closeEventModal();
                const eventName = event.eventname || `Event ${event.eventoccurrenceid}`;
                openDeleteModal(`/mEvent/delete/${event.eventoccurrenceid}`, eventName);
            };
        }

        // Close event modal
        function closeEventModal() {
            const modal = document.getElementById('eventDetailModal');
            modal.classList.remove('active');
            currentEventData = null;
        }

        // Close modal when clicking outside
        document.getElementById('eventDetailModal').addEventListener('click', function(e) {
            if (e.target === this) {
                closeEventModal();
            }
        });

        // Close modal on ESC key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closeEventModal();
                closeSurveyCommentModal();
            }
        });

        // Open survey comment modal
        function openSurveyCommentModal(participantName, surveyIndex) {
            const modal = document.getElementById('surveyCommentModal');
            const modalName = document.getElementById('surveyCommentModalName');
            const modalBody = document.getElementById('surveyCommentModalBody');
            const commentText = document.getElementById('surveyCommentText');
            
            if (!window.currentSurveyData || !window.currentSurveyData[surveyIndex]) {
                console.error('Survey data not found');
                return;
            }
            
            const survey = window.currentSurveyData[surveyIndex];
            const comment = survey.surveycomments || '';
            
            modalName.textContent = `Survey Comment - ${participantName}`;
            
            if (comment && comment.trim()) {
                // Escape HTML and preserve line breaks
                const escapedComment = comment
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#039;');
                commentText.innerHTML = escapedComment.replace(/\n/g, '<br>');
                commentText.style.color = 'var(--text-dark)';
            } else {
                commentText.textContent = 'No comment provided.';
                commentText.style.color = 'var(--text-light)';
                commentText.style.fontStyle = 'italic';
            }
            
            modal.classList.add('active');
        }

        // Close survey comment modal
        function closeSurveyCommentModal() {
            const modal = document.getElementById('surveyCommentModal');
            modal.classList.remove('active');
        }

        // Close survey comment modal when clicking outside
        document.getElementById('surveyCommentModal').addEventListener('click', function(e) {
            if (e.target === this) {
                closeSurveyCommentModal();
            }
        });

        // Keep existing functions for edit modal
        function openEventModalFromButton(button, modalId) {
            const data = {
                eventoccurrenceid: button.getAttribute('data-eventoccurrenceid') || '',
                eventtypeid: button.getAttribute('data-eventtypeid') || '',
                eventname: button.getAttribute('data-eventname') || '',
                eventdatetimestart: button.getAttribute('data-eventdatetimestart') || '',
                eventdatetimeend: button.getAttribute('data-eventdatetimeend') || '',
                eventlocation: button.getAttribute('data-eventlocation') || '',
                eventcapacity: button.getAttribute('data-eventcapacity') || '',
                eventregistrationdeadline: button.getAttribute('data-eventregistrationdeadline') || ''
            };
            openModal(modalId, 'edit', data);
        }
    </script>
</body>
</html>
