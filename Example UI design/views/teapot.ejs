<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">
    <title>418 I'm a Teapot - Ella Rises</title>
    <link rel="icon" type="image/png" href="/Ella Rises Logo (3).png">
    <link rel="stylesheet" href="/styles.css">
    <style>
        body {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            background-color: var(--white);
        }
        .teapot-container {
            text-align: center;
            padding: 2rem;
        }
        .teapot-code {
            font-size: 8rem;
            font-weight: bold;
            color: var(--sage-green);
            margin-bottom: 1rem;
            font-family: 'DM Serif Display', serif;
        }
        .teapot-message {
            font-size: 2rem;
            color: var(--dark-charcoal);
            margin-bottom: 2rem;
            font-family: 'DM Serif Display', serif;
        }
        .teapot-description {
            font-size: 1.2rem;
            color: var(--text-light);
            margin-bottom: 2rem;
        }
        .btn {
            display: inline-block;
            padding: 0.75rem 2rem;
            background: var(--sage-green);
            color: var(--white);
            text-decoration: none;
            border-radius: 25px;
            transition: all 0.3s;
            font-weight: 500;
        }
        .btn:hover {
            background: var(--dark-charcoal);
            transform: translateY(-2px);
        }
    </style>
</head>
<body>
    <div class="teapot-container">
        <div class="teapot-code">418</div>
        <div class="teapot-message">I'm a Teapot</div>
        <div class="teapot-description">This server is a teapot and cannot brew coffee.</div>
        <a href="/mUser" class="btn">Return to User Maintenance</a>
    </div>
</body>
</html>
