<!-- Delete Confirmation Modal -->
<div id="deleteConfirmModal" class="modal" style="display: none;">
    <div class="modal-content delete-modal">
        <div class="delete-modal-header">
            <span class="delete-icon">⚠️</span>
            <h2>Confirm Deletion</h2>
        </div>
        <p id="deleteConfirmMessage">Are you sure you want to delete this item?</p>
        <p class="delete-warning">This action cannot be undone.</p>
        
        <form id="deleteForm" method="POST" action="">
            <div class="form-actions delete-actions">
                <button type="button" class="btn btn-secondary" onclick="closeDeleteModal()">Cancel</button>
                <button type="submit" class="btn btn-danger">Delete</button>
            </div>
        </form>
    </div>
</div>

<style>
.delete-modal {
    max-width: 450px;
    text-align: center;
}

.delete-modal-header {
    margin-bottom: 1rem;
}

.delete-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: 0.5rem;
}

.delete-modal h2 {
    color: var(--danger, #CE325B);
    margin-bottom: 1rem;
}

.delete-modal p {
    color: var(--text-dark, #3A3F3B);
    margin-bottom: 0.5rem;
}

.delete-warning {
    color: var(--text-light, #666666);
    font-size: 0.9rem;
    font-style: italic;
}

.delete-actions {
    justify-content: center;
    margin-top: 1.5rem;
}
</style>

<script>
function openDeleteModal(endpoint, itemName) {
    const modal = document.getElementById('deleteConfirmModal');
    const form = document.getElementById('deleteForm');
    const message = document.getElementById('deleteConfirmMessage');
    
    form.action = endpoint;
    message.textContent = `Are you sure you want to delete "${itemName}"?`;
    
    modal.style.display = 'block';
}

function closeDeleteModal() {
    const modal = document.getElementById('deleteConfirmModal');
    modal.style.display = 'none';
}

// Close modal when clicking outside
document.addEventListener('click', function(event) {
    const modal = document.getElementById('deleteConfirmModal');
    if (event.target === modal) {
        modal.style.display = 'none';
    }
});
</script>

