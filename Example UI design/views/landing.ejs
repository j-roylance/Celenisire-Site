<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">
    <title>Ella Rises - Empowering Women in Crisis</title>
    <link rel="icon" type="image/png" href="/Ella Rises Logo (3).png">
    <link rel="stylesheet" href="styles.css">
    <style>
        /* Smooth scrolling */
        html {
            scroll-behavior: smooth;
            overflow-y: auto;
        }

        body {
            overflow-y: auto !important;
            overflow-x: hidden;
        }

        /* Override flex for landing page sections to prevent layout issues */
        .landing-section.section {
            flex: 0 0 auto;
        }

        .hero.section {
            flex: 0 0 auto;
        }

        /* Landing page specific styles */
        .landing-section {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1), transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .landing-section.visible {
            opacity: 1;
            transform: translateY(0);
        }

        .landing-section.fade-out {
            opacity: 0;
            transform: translateY(-30px);
        }

        /* Carousel styles */
        .sponsors-carousel {
            position: relative;
            overflow: hidden;
            width: 100%;
            padding: 2rem 0;
            mask-image: linear-gradient(to right, transparent 0%, black 5%, black 95%, transparent 100%);
            -webkit-mask-image: linear-gradient(to right, transparent 0%, black 5%, black 95%, transparent 100%);
        }

        .sponsors-track {
            display: flex;
            gap: 2rem;
            animation: scroll 30s linear infinite;
            will-change: transform;
            width: fit-content;
        }

        .sponsors-track:hover {
            animation-play-state: paused;
        }

        .sponsor-card {
            flex-shrink: 0;
            width: 280px;
            height: 180px;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.5);
            box-shadow: 0 8px 32px rgba(0,0,0,0.1);
            padding: 1rem;
            border-radius: 20px;
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }
        
        @media (max-width: 768px) {
            .sponsor-card {
                width: 200px;
                height: 130px;
                padding: 0.75rem;
            }
        }
        
        @media (max-width: 480px) {
            .sponsor-card {
                width: 160px;
                height: 100px;
                padding: 0.5rem;
            }
        }

        .sponsor-card img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
            border-radius: 12px;
        }

        .sponsor-card:hover {
            transform: translateY(-8px) scale(1.05);
            box-shadow: 0 12px 40px rgba(0,0,0,0.15);
        }

        @keyframes scroll {
            0% {
                transform: translateX(0);
            }
            100% {
                transform: translateX(calc(-280px * 13 - 2rem * 13));
            }
        }

        .hero-content h1 {
            animation: fadeInUp 1s cubic-bezier(0.4, 0, 0.2, 1) 0.2s both;
        }

        .hero-content p {
            animation: fadeInUp 1s cubic-bezier(0.4, 0, 0.2, 1) 0.4s both;
        }

        .hero-content .btn {
            animation: fadeInUp 1s cubic-bezier(0.4, 0, 0.2, 1) 0.6s both;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Smooth card animations */
        .card {
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .card:hover {
            transform: translateY(-10px) scale(1.02);
        }

        /* Stat card animations */
        .stat-card {
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .stat-card:hover {
            transform: translateY(-8px) scale(1.05);
        }

        /* Video container smooth reveal */
        .video-container {
            opacity: 0;
            transform: scale(0.95);
            transition: opacity 1.2s cubic-bezier(0.4, 0, 0.2, 1), transform 1.2s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .video-container.visible {
            opacity: 1;
            transform: scale(1);
        }
        
        .responsive-video {
            width: 100%;
            height: auto;
            min-height: 50vh;
        }
        
        @media (max-width: 768px) {
            .responsive-video {
                min-height: 40vh;
            }
            
            .hero-content .btn {
                width: 100%;
                max-width: 300px;
            }
        }
        
        @media (max-width: 480px) {
            .responsive-video {
                min-height: 30vh;
            }
            
            .hero-content .btn {
                width: 100%;
                max-width: 100%;
            }
        }
    </style>
</head>
<body class="landing-page">
